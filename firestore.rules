rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- User Profiles & Data ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // Allow access to all subcollections for the owner
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Global Social Annotations ---
    match /annotations/{annotationId} {
      // Allow anyone to read annotations to foster community learning
      allow read: if true; 
      // Only authenticated users can create, and only owners can update/delete
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}