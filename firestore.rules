rules_version = '2';

/**
 * FIRESTORE SECURITY RULES - PROTOTYPING MODE
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model where private data is sequestered 
 * within user-specific subtrees. It prioritizes strong authorization (who can access what) 
 * while maintaining flexibility on the internal shape of data to support rapid prototyping.
 *
 * Data Structure:
 * - /users/{userId}: Root profile documents for authenticated users.
 * - /users/{userId}/user_progress/{id}: Private tracking of learning stages.
 * - /users/{userId}/annotations/{id}: Private user notes and verse highlights.
 * - /reading_paths/{id}: Public, read-only curated Bible engagement paths.
 * - /reading_paths/{id}/reading_units/{id}: Public, read-only modules within a path.
 *
 * Key Security Decisions:
 * 1. Ownership Model: All user-related data uses path-based wildcards. Access is granted 
 *    only if the wildcard {userId} matches the authenticated user's UID.
 * 2. Denormalization for Authorization: User IDs are stored both in the path and inside 
 *    the documents. Rules enforce that these match during creation and remain immutable.
 * 3. Public Content: Content curated by administrators (Reading Paths/Units) is globally 
 *    readable but restricted from client-side writes to prevent unauthorized modification.
 * 4. Structural Segregation: User progress and annotations are nested under the user 
 *    document, ensuring that list operations are naturally scoped to the owner.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** Checks if the user is authenticated with a valid UID. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Combines ownership verification with a check for document existence. 
     * Used for update and delete operations to ensure destructive actions 
     * only happen on valid, owned resources.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profile documents.
     * @path /users/{userId}
     * @allow (get, create) User 'abc' accessing/creating /users/abc.
     * @deny (list, update) User 'abc' attempting to modify /users/xyz.
     * @principle Path-based ownership and self-creation validation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Tracks a user's progress through 'Guided Ascent' stages.
       * @path /users/{userId}/user_progress/{progressId}
       * @allow (create) User 'abc' adding progress to their own subcollection.
       * @deny (get) User 'abc' reading progress belonging to user 'def'.
       * @principle Nested resource ownership and relational integrity.
       */
      match /user_progress/{progressId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description User's private highlights and comments on Bible verses.
       * @path /users/{userId}/annotations/{annotationId}
       * @allow (list) User 'abc' querying their own annotations.
       * @deny (update) User 'abc' trying to change the 'userId' field on an existing annotation.
       * @principle Enforces immutability of the ownership link.
       */
      match /annotations/{annotationId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Curated Bible reading paths available to all users.
     * @path /reading_paths/{readingPathId}
     * @allow (get, list) Any user (even signed out) viewing the library of paths.
     * @deny (create, update, delete) Any client-side write operation.
     * @principle Publicly readable content with restricted administrative writes.
     */
    match /reading_paths/{readingPathId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // Managed via Admin SDK or Console
      allow update: if false;
      allow delete: if false;

      /**
       * @description Individual units within a reading path.
       * @path /reading_paths/{readingPathId}/reading_units/{unitId}
       * @allow (get) Publicly fetching details for a specific unit.
       * @deny (update) Unauthorized attempt to modify unit order or content.
       * @principle Inherits public-read posture from parent resource.
       */
      match /reading_units/{unitId} {
        allow get: if true;
        allow list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}