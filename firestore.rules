rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Deployment Trigger: 2024-05-22T10:00:00Z - Ensuring public read access for annotations

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- User Profiles & Private Data ---
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // Allow access to private subcollections (like private annotations)
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- User Progress Tracking ---
    match /user_progress/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Global Social Annotations (The Living Commentary) ---
    match /annotations/{annotationId} {
      // PUBLIC READ: Allow anyone (even guests) to read the community feed
      allow read: if true; 
      
      // AUTHENTICATED WRITE: Only logged-in users can create insights
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // OWNER ONLY: Only the original scholar can update or delete their insight
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}