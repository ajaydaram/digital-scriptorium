
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "displayName", "email", "createdAt", "updatedAt"]
    },
    "UserProgress": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProgress",
      "type": "object",
      "description": "Tracks a specific user's progress through a ReadingUnit.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "readingUnitId": { "type": "string" },
        "currentStage": { "type": "string", "enum": ["Read", "Understand", "Master"] },
        "startedAt": { "type": "string", "format": "date-time" },
        "lastAccessedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "readingUnitId", "currentStage", "startedAt", "lastAccessedAt"]
    },
    "Annotation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Annotation",
      "type": "object",
      "description": "A user-created note or highlight on a scripture passage.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "passageRef": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "passageRef", "content", "createdAt"]
    },
    "UserWordStudy": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserWordStudy",
      "type": "object",
      "description": "Saved word studies for a user.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "word": { "type": "string" },
        "originalWord": { "type": "string" },
        "transliteration": { "type": "string" },
        "definition": { "type": "string" },
        "theologicalSignificance": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "word", "originalWord", "definition", "createdAt"]
    },
    "ReadingPath": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ReadingPath",
      "type": "object",
      "description": "A curated study journey.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["chronological", "thematic", "genre"] }
      },
      "required": ["id", "title", "description", "type"]
    }
  },
  "auth": {
    "providers": ["google.com", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profile data."
    },
    "/users/{userId}/user_progress/{progressId}": {
      "schema": "UserProgress",
      "description": "Private study progress tracking."
    },
    "/users/{userId}/annotations/{annotationId}": {
      "schema": "Annotation",
      "description": "Private user notes and verse highlights."
    },
    "/users/{userId}/word_studies/{studyId}": {
      "schema": "UserWordStudy",
      "description": "Private log of performed word studies."
    },
    "/reading_paths/{pathId}": {
      "schema": "ReadingPath",
      "description": "Public curated study paths."
    }
  }
}
