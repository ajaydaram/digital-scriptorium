{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores profile information and application-specific settings for a user.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName"]
    },
    "Annotation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Annotation",
      "type": "object",
      "description": "Represents a user's highlight and associated comment on a specific scripture passage.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "userAvatarUrl": { "type": "string" },
        "passageRef": { "type": "string" },
        "highlightedText": { "type": "string" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "passageRef", "comment", "createdAt"]
    },
    "UserProgress": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProgress",
      "type": "object",
      "description": "Tracks a user's progress through a reading path or specific passage.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "pathId": { "type": "string" },
        "currentDay": { "type": "number" },
        "currentStage": { "type": "string", "enum": ["read", "understand", "master"] },
        "lastAccessedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "Individual user profiles."
        }
      },
      {
        "path": "/user_progress/{userId}/units/{unitId}",
        "definition": {
          "entityName": "UserProgress",
          "description": "Detailed progress tracking for reading units."
        }
      },
      {
        "path": "/annotations/{annotationId}",
        "definition": {
          "entityName": "Annotation",
          "description": "Public community insights on scripture."
        }
      }
    ]
  }
}