{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores profile information and application-specific settings for a user.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName"]
    },
    "Annotation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Annotation",
      "type": "object",
      "description": "Represents a user's highlight and associated comment on a specific scripture passage.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "userAvatarUrl": { "type": "string" },
        "passageRef": { "type": "string" },
        "highlightedText": { "type": "string" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "circleId": { "type": "string" },
        "parentId": { "type": "string" },
        "reactions": {
          "type": "object",
          "properties": {
            "insightful": { "type": "array", "items": { "type": "string" } },
            "needsContext": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "required": ["userId", "passageRef", "comment", "createdAt"]
    },
    "UserProgress": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProgress",
      "type": "object",
      "description": "Tracks a user's progress through a reading path or specific passage.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "pathId": { "type": "string" },
        "currentDay": { "type": "number" },
        "currentStage": { "type": "string", "enum": ["read", "understand", "master"] },
        "lastAccessedAt": { "type": "string", "format": "date-time" }
    },
    "StudyCircle": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StudyCircle",
      "type": "object",
      "description": "Represents a private study group or room.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "readingPath": { "type": "string" },
        "currentDay": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "memberIds", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles and settings."
    },
    "/user_progress/{userId}": {
      "schema": "UserProgress",
      "description": "Top-level user progress data."
    },
    "/user_progress/{userId}/units/{unitId}": {
      "schema": "UserProgress",
      "description": "Detailed progress tracking for specific reading units."
    },
    "/annotations/{annotationId}": {
      "schema": "Annotation",
      "description": "Public community insights on scripture, readable by all, writable by owners."
    },
    "/circles/{circleId}": {
      "schema": "StudyCircle",
      "description": "Private study circles/rooms."
    },
    "/circles/{circleId}/annotations/{annotationId}": {
      "schema": "Annotation",
      "description": "Annotations shared privately within a study circle."
    }
  }
}